# ── Cryton environment variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is listed in .gitignore.

SECRET_KEY=change-this-to-a-long-random-string

# ── Brevo SMTP ────────────────────────────────────────────────────
# Find these at: app.brevo.com → SMTP & API → SMTP tab
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=ab2f44001@smtp-brevo.com   # "Login" value shown in Brevo
MAIL_PASSWORD=xsmtpsib-your-key-here     # generate under "Your SMTP Keys"

# Where contact form submissions are delivered
CONTACT_RECIPIENT=hello@cryton.no
